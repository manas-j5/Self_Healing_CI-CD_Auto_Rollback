# ================================================================
# .gitignore — Self-Healing CI/CD Project
# ================================================================

# ---- Environment Variables (NEVER commit real secrets!) ----
.env
*.env.local

# ---- Java / Maven Build Output ----
app/target/
app/*.class
*.jar
*.war
*.ear

# ---- Maven wrapper ----
!app/mvnw
!app/.mvn/

# ---- IDE Files ----
.idea/
*.iml
.vscode/
*.swp
*.swo
.DS_Store

# ---- Logs ----
*.log
logs/

# ---- Docker ----
.dockerignore

# ---- OS ----
Thumbs.db
ehthumbs.db
