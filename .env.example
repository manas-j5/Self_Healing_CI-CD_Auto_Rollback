# ================================================================
# .env.example — Environment Variables Reference
# ================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file with real secrets to Git.
# Use GitHub Secrets for CI/CD pipeline variables.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
# ================================================================

# ----------------------------------------------------------------
# Docker Configuration
# ----------------------------------------------------------------

# Your Docker Hub username (matches GitHub Secret: DOCKERHUB_USERNAME)
DOCKER_IMAGE=yourdockerhub/selfhealing-app

# Application version tag to deploy (e.g., v1, v2, latest)
# Set automatically by CI pipeline as v{run_number}
APP_VERSION=latest

# ----------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------

# Application environment (development | staging | production)
APP_ENV=production

# Application name (used in notifications and logs)
APP_NAME=selfhealing-app

# ----------------------------------------------------------------
# Deployment Ports (Blue-Green)
# ----------------------------------------------------------------

# PORT_BLUE and PORT_GREEN are hardcoded in deploy.sh (8080 and 8081)
# but you can override them here if needed:
# PORT_BLUE=8080
# PORT_GREEN=8081

# ----------------------------------------------------------------
# Health Check Configuration
# ----------------------------------------------------------------

# Time (seconds) to wait before first health check after container starts
HEALTH_WAIT_SECONDS=15

# Maximum total seconds to spend on health checks before rollback
MAX_WAIT_SECONDS=60

# ----------------------------------------------------------------
# Nginx Configuration
# ----------------------------------------------------------------

# Path to the Nginx app config file that controls upstream routing
NGINX_CONF=/etc/nginx/conf.d/app.conf

# ----------------------------------------------------------------
# Logging
# ----------------------------------------------------------------

# Directory where deployment logs are stored on the EC2 instance
LOG_DIR=/var/log/deployments

# ----------------------------------------------------------------
# Notifications
# ----------------------------------------------------------------

# Email address to receive deployment success/failure alerts (optional)
# Requires 'mail' or 'sendmail' to be installed on the EC2 instance
# sudo apt-get install mailutils
NOTIFICATION_EMAIL=your-email@example.com

# Slack incoming webhook URL for deployment notifications (optional)
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ----------------------------------------------------------------
# Docker Hub Credentials (for EC2 to pull images)
# ----------------------------------------------------------------

# Docker Hub username (same as DOCKER_IMAGE prefix)
DOCKERHUB_USERNAME=yourdockerhub

# Docker Hub access token (not your password)
# Create at https://hub.docker.com/settings/security → New Access Token
# On EC2, run: docker login -u $DOCKERHUB_USERNAME -p $DOCKERHUB_TOKEN
DOCKERHUB_TOKEN=your-dockerhub-access-token

# ----------------------------------------------------------------
# AWS / EC2 (used in README setup instructions, not by scripts)
# ----------------------------------------------------------------

# EC2 public IP or hostname (for reference)
EC2_HOST=your-ec2-public-ip

# EC2 SSH user (default: ubuntu for Ubuntu AMIs)
EC2_USER=ubuntu
